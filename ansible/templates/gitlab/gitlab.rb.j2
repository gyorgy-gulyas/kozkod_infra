# KözKód GitLab CE konfiguráció
# Ansible által kezelt — ne szerkeszd kézzel!

external_url 'https://{{ gitlab_domain }}'

# ── Nginx ─────────────────────────────────────────────────────────────────────
# Beépített Nginx kikapcsolva — a mi Nginx-ünk kezeli a gitlab.kozkod.hu-t
nginx['enable'] = false
web_server['external_users'] = ['www-data']

# GitLab Workhorse belső TCP porton (Nginx ide proxyza)
gitlab_workhorse['listen_network'] = 'tcp'
gitlab_workhorse['listen_addr'] = '127.0.0.1:8181'

# ── Regisztráció és auth ──────────────────────────────────────────────────────
# Csak a platform API hozhat létre felhasználót
gitlab_rails['gitlab_signup_enabled'] = false
gitlab_rails['gitlab_default_can_create_group'] = false

# Web belépés letiltva — a platform impersonation token-t ad Git műveletekhez
gitlab_rails['password_authentication_enabled_for_web'] = false
gitlab_rails['password_authentication_enabled_for_git'] = true

# ── Email ─────────────────────────────────────────────────────────────────────
gitlab_rails['smtp_enable'] = true
gitlab_rails['smtp_address'] = '{{ email_host }}'
gitlab_rails['smtp_port'] = {{ email_port }}
gitlab_rails['smtp_user_name'] = '{{ email_host_user }}'
gitlab_rails['smtp_password'] = '{{ email_host_password }}'
gitlab_rails['smtp_domain'] = 'kozkod.hu'
gitlab_rails['smtp_authentication'] = 'login'
gitlab_rails['smtp_enable_starttls_auto'] = true
gitlab_rails['gitlab_email_from'] = '{{ email_host_user }}'
gitlab_rails['gitlab_email_reply_to'] = '{{ email_host_user }}'

# ── Letiltott komponensek ─────────────────────────────────────────────────────
# Alertmanager — nem szükséges, letiltva (timeout okoz reconfigure-nál)
alertmanager['enable'] = false

# Container Registry, Pages, Package Registry — admin UI-ban tiltjuk le
# FONTOS: gitlab.rb-beli letiltásuk cinc-client deadlockot okoz GitLab 19-ben

# ── Egyéb ─────────────────────────────────────────────────────────────────────
gitlab_rails['time_zone'] = 'Europe/Budapest'
gitlab_rails['backup_keep_time'] = 604800

# Web IDE single origin fallback letiltás (security)
gitlab_rails['vscode_web_ide_extensions_marketplace_check_timeout'] = 5

# Let's Encrypt kikapcsolva — certbot kezeli
letsencrypt['enable'] = false
