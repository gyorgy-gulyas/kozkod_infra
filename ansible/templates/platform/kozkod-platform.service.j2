[Unit]
Description=KözKód Platform Gunicorn
After=network.target postgresql.service

[Service]
User=www-data
WorkingDirectory={{ platform_dir }}/backend
Environment=DJANGO_SETTINGS_MODULE=config.settings.production
Environment=HOME=/tmp
EnvironmentFile={{ platform_dir }}/backend/.env
ExecStart={{ platform_dir }}/backend/.venv/bin/gunicorn config.wsgi:application --bind 127.0.0.1:8001 --workers 3 --worker-tmp-dir /tmp --timeout 60
Restart=always

[Install]
WantedBy=multi-user.target
