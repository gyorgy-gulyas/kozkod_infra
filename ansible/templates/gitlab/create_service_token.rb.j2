# KözKód platform service account token létrehozása
# Megjegyzés: GitLab 16+ digest-ként tárolja a tokent, raw érték csak create! után
# Megjegyzés: GitLab max 1 éves tokent engedélyez (expires_at kötelező)
# Megjegyzés: output /tmp/-be kerül (git user write jog)

# Régi tokenek visszavonása
PersonalAccessToken.where(name: 'kozkod-platform-service').update_all(revoked: true)

user = User.find_by(username: 'root')
token = PersonalAccessToken.create!(
  user: user,
  name: 'kozkod-platform-service',
  scopes: ['api', 'read_user', 'sudo'],
  expires_at: 364.days.from_now
)

# Raw token csak közvetlenül create! után érhető el
File.write('/tmp/service_token.txt', token.token)
