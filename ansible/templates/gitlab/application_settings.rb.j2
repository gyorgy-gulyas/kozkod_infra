# GitLab ApplicationSetting értékek beállítása
# Idempotens — minden futáskor frissíti

s = ApplicationSetting.current_without_cache

# Signup letiltás — csak platform API hozhat létre usert
s.signup_enabled = false

# Max token lifetime 365 napra
s.max_personal_access_token_lifetime = 365

# Alapértelmezett láthatóság: privát
s.default_project_visibility = Gitlab::VisibilityLevel::PRIVATE
s.default_group_visibility = Gitlab::VisibilityLevel::PRIVATE
s.default_snippet_visibility = Gitlab::VisibilityLevel::PRIVATE

# Publikus és belső láthatóság tiltása — csak privát projektek lehetségesek
s.restricted_visibility_levels = [Gitlab::VisibilityLevel::PUBLIC, Gitlab::VisibilityLevel::INTERNAL]

# Külső import letiltása
s.import_sources = []

# Helyi hálózatra menő webhookok engedélyezése — a platform (platform.kozkod.hu)
# ugyanazon a szerveren fut, így a GitLab alapból blokkolná a webhook-kézbesítést
# ÉS a webhook létrehozását is. Ez kell ahhoz, hogy az MR/push hookok működjenek.
s.allow_local_requests_from_web_hooks_and_services = true

# Főoldal: üres = GitLab a saját sign_in oldalára irányít, ahol az OmniAuth auto-sign-in fut
s.home_page_url = ''

# Projekt létrehozás tiltása — a platform kezeli a GitLab group/repo struktúrát
s.default_projects_limit = 0

# Új userek alapból external — csak a hozzájuk rendelt projekteket látják
s.user_default_external = true

s.save!
puts 'ApplicationSetting mentve'
puts "default_projects_limit: #{s.default_projects_limit}"
puts "user_default_external: #{s.user_default_external}"
puts "restricted_visibility_levels: #{s.restricted_visibility_levels}"

# Meglévő nem-admin userek frissítése (idempotens)
updated = User.where(admin: false).where('projects_limit != 0 OR external = false').count
User.where(admin: false).update_all(projects_limit: 0, external: true)
puts "Meglévő userek frissítve: #{updated}"
